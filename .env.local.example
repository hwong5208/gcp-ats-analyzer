# Local Development Environment Variables
# Copy to .env.local and fill in your values

# ============================================
# LLM Configuration (choose one)
# ============================================

# Option 1: Use Local LLM (recommended for testing)
LOCAL_LLM_ENDPOINT=http://10.0.0.95:1234/v1/chat/completions
LOCAL_LLM_MODEL=HauhauCS/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive

# Option 2: Use Vertex AI (requires GCP credentials)
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Environment
ENVIRONMENT=dev
